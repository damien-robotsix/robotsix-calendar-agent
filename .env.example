# robotsix-calendar-agent configuration
# Copy to .env and fill in your Radicale server credentials.

# Logging
LOG_LEVEL=INFO
JSON_LOGS=false
RADICALE_URL=https://radicale.example.com
RADICALE_USERNAME=your-username
RADICALE_PASSWORD=your-password
# Default calendar name for write operations when no calendar_id is provided.
# RADICALE_DEFAULT_CALENDAR=Robotsix

# Transport selection: "inprocess" (default, in-memory Registry) or
# "brokered" (connect to a secured TLS broker).
CALENDAR_AGENT_TRANSPORT=inprocess

# Calendar agent identity on the broker (default: robotsix-calendar).
# CALENDAR_AGENT_ID=robotsix-calendar

# Broker connection (required when CALENDAR_AGENT_TRANSPORT=brokered).
BROKER_HOST=broker.example.com
BROKER_PORT=9090
BROKER_SCHEME=https
# Path to the CA certificate PEM used to verify the broker.
BROKER_TLS_CA=/certs/ca.pem
# Optional client certificate + key for mutual TLS (mTLS).
BROKER_CLIENT_CERT=/certs/client.pem
BROKER_CLIENT_KEY=/certs/client.key
# Authentication token presented to the broker.
BROKER_AGENT_TOKEN=your-broker-token

# Component-agent responder (optional management layer: monitor/config-get/config-set).
# COMPONENT_AGENT_ENABLED=false
# COMPONENT_AGENT_TOKEN=
# COMPONENT_AGENT_ID=robotsix-calendar
