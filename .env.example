# robotsix-calendar-agent configuration
# Copy to .env and fill in your Radicale server credentials.

# Logging
LOG_LEVEL=INFO
JSON_LOGS=false
RADICALE_URL=https://radicale.example.com
RADICALE_USERNAME=your-username
RADICALE_PASSWORD=your-password
# Default calendar name for write operations when no calendar_id is provided.
# RADICALE_DEFAULT_CALENDAR=Robotsix
# Timeout in seconds for CalDAV HTTP requests (default 30).
# CALDAV_TIMEOUT=30
